{
  "name": "@cloudflare-monitor/api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for Cloudflare deployment monitoring",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare-monitor/shared": "workspace:*",
    "arg": "^5.0.2",
    "hono": "^4.12.27",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "overrides": {
    "flatted": "3.4.2",
    "minimatch@<3.1.3": "3.1.3",
    "minimatch@>=9.0.0 <9.0.7": "9.0.8"
  }
}
